FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build the node binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /app/coder-node ./cmd/coder-node

FROM alpine:latest

# Install CA certificates since we make outbound HTTP calls to Ollama
RUN apk --no-cache add ca-certificates curl

WORKDIR /app
COPY --from=builder /app/coder-node /app/coder-node

EXPOSE 50051 8080

ENTRYPOINT ["/app/coder-node"]
